{
  "agents": {
    "defaults": {
      "workspace": "./.openclaw/workspaces/main",
      "model": "ollama/kimi-k2.5:cloud",
      "userTimezone": "America/Los_Angeles"
    },
    "list": [
      {
        "id": "executive-producer",
        "name": "Executive Producer",
        "default": true,
        "workspace": "./.openclaw/workspaces/executive-producer",
        "identity": {
          "name": "Executive Producer",
          "theme": "visionary film producer",
          "emoji": "🎬"
        },
        "tools": {
          "profile": "full",
          "deny": ["canvas", "nodes", "cron", "message"],
          "allow": [
            "group:sessions",
            "group:memory",
            "group:fs",
            "group:web",
            "group:runtime",
            "session_status",
            "image"
          ]
        },
        "subagents": {
          "allowAgents": ["*"]
        }
      },
      {
        "id": "creative-director",
        "name": "Creative Director",
        "workspace": "./.openclaw/workspaces/creative-director",
        "identity": {
          "name": "Creative Director",
          "theme": "artistic vision lead",
          "emoji": "🎨"
        },
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:web",
            "group:memory",
            "image",
            "browser"
          ],
          "deny": ["group:runtime", "canvas", "nodes", "cron", "message"]
        }
      },
      {
        "id": "script-architect",
        "name": "Script Architect",
        "workspace": "./.openclaw/workspaces/script-architect",
        "identity": {
          "name": "Script Architect",
          "theme": "narrative structure expert",
          "emoji": "📝"
        },
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:web",
            "group:memory"
          ],
          "deny": ["group:runtime", "browser", "canvas", "nodes", "cron", "message", "image"]
        }
      },
      {
        "id": "shot-planner",
        "name": "Shot Planner",
        "workspace": "./.openclaw/workspaces/shot-planner",
        "identity": {
          "name": "Shot Planner",
          "theme": "cinematography specialist",
          "emoji": "📷"
        },
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:web",
            "group:memory",
            "image"
          ],
          "deny": ["group:runtime", "canvas", "nodes", "cron", "message"]
        }
      },
      {
        "id": "post-supervisor",
        "name": "Post Supervisor",
        "workspace": "./.openclaw/workspaces/post-supervisor",
        "identity": {
          "name": "Post Supervisor",
          "theme": "post-production workflow manager",
          "emoji": "🎞️"
        },
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:runtime",
            "group:web",
            "group:memory"
          ],
          "deny": ["browser", "canvas", "nodes", "cron", "message", "image"]
        }
      },
      {
        "id": "campaign-strategist",
        "name": "Campaign Strategist",
        "workspace": "./.openclaw/workspaces/campaign-strategist",
        "identity": {
          "name": "Campaign Strategist",
          "theme": "marketing and distribution planner",
          "emoji": "📢"
        },
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:web",
            "group:memory",
            "browser"
          ],
          "deny": ["group:runtime", "canvas", "nodes", "cron", "image"]
        }
      },
      {
        "id": "asset-librarian",
        "name": "Asset Librarian",
        "workspace": "./.openclaw/workspaces/asset-librarian",
        "identity": {
          "name": "Asset Librarian",
          "theme": "media asset organization specialist",
          "emoji": "📚"
        },
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:runtime",
            "group:memory",
            "image"
          ],
          "deny": ["browser", "canvas", "nodes", "cron", "message", "group:web"]
        }
      }
    ]
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://localhost:11434/v1",
        "api": "openai-completions",
        "injectNumCtxForOpenAICompat": true,
        "models": [
          {
            "id": "kimi-k2.5:cloud",
            "name": "Kimi K2.5 Cloud",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 32000
          }
        ]
      }
    }
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": { "enabled": true },
      "fetch": { "enabled": true }
    },
    "loopDetection": {
      "enabled": true,
      "historySize": 30,
      "warningThreshold": 8,
      "criticalThreshold": 16,
      "globalCircuitBreakerThreshold": 30,
      "detectors": {
        "genericRepeat": true,
        "knownPollNoProgress": true,
        "pingPong": true
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback"
  },
  "ui": {
    "seamColor": "#00f0ff",
    "assistant": {
      "name": "metaVstudio",
      "avatar": "🎬"
    }
  }
}
